# ============================================================================
# AER Project - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ============================================================================
# Flask Configuration
# ============================================================================
FLASK_APP=app
FLASK_ENV=development  # development or production
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0
PORT=5000
WORKERS=4  # For gunicorn

# ============================================================================
# API Keys (REQUIRED)
# ============================================================================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-org-id  # Optional

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Hugging Face
HUGGINGFACE_TOKEN=hf_your-token-here

# ============================================================================
# Model Configuration
# ============================================================================
DEFAULT_MODEL=gpt-4
EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2
MAX_TOKENS=1000
TEMPERATURE=0.3
TOP_P=0.9

# ============================================================================
# Database
# ============================================================================
# SQLite (Development)
DATABASE_URL=sqlite:///aer.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://user:password@localhost:5432/aer_db

# ============================================================================
# Redis (Optional - for caching)
# ============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=3600

# ============================================================================
# Paths
# ============================================================================
DATA_DIR=./data
OUTPUT_DIR=./outputs
CACHE_DIR=./outputs/cache
MODELS_DIR=./outputs/models
LOGS_DIR=./outputs/logs

# ============================================================================
# Retrieval Configuration
# ============================================================================
VECTOR_STORE_TYPE=faiss  # faiss or chromadb
TOP_K_DOCUMENTS=5
RERANK_ENABLED=true
SIMILARITY_THRESHOLD=0.7

# ============================================================================
# Experiment Tracking
# ============================================================================
# Weights & Biases
WANDB_API_KEY=your-wandb-key
WANDB_PROJECT=aer-project
WANDB_ENTITY=your-username

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=aer-experiments

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# Security
# ============================================================================
ENABLE_AUTH=false  # Set to true in production
JWT_SECRET_KEY=your-jwt-secret-key
SESSION_COOKIE_SECURE=false  # Set to true in production (HTTPS)
SESSION_COOKIE_HTTPONLY=true

# ============================================================================
# API Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Performance
# ============================================================================
MAX_CONTENT_LENGTH=16777216  # 16MB
REQUEST_TIMEOUT=300  # seconds
ENABLE_CACHE=true

# ============================================================================
# Monitoring (Optional)
# ============================================================================
SENTRY_DSN=your-sentry-dsn-here
ENABLE_PROFILING=false

# ============================================================================
# End of Configuration
# ============================================================================