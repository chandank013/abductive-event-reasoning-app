# ======================================
# Project Specific - Data
# ======================================
# Raw data (too large for git)
data/raw/*.jsonl
data/raw/*.json
data/raw/*.csv
data/raw/*.txt
data/raw/*.zip
data/raw/*.tar.gz

# Keep directory structure but ignore contents
data/raw/*
!data/raw/.gitkeep

# Processed data
data/processed/train/*.jsonl
data/processed/dev/*.jsonl
data/processed/test/*.jsonl
data/processed/*/*.json
data/processed/*/*.pkl

# Keep directory structure
!data/processed/train/.gitkeep
!data/processed/dev/.gitkeep
!data/processed/test/.gitkeep

# Embeddings (large binary files)
data/embeddings/*.npy
data/embeddings/*.pkl
data/embeddings/*.faiss
data/embeddings/*.index
data/embeddings/*
!data/embeddings/.gitkeep

# Temporary data files
data/tmp/
data/temp/
data/cache/

# ======================================
# Project Specific - Outputs
# ======================================
# Model predictions
outputs/predictions/*.jsonl
outputs/predictions/*.json
outputs/predictions/*.csv

# Logs
outputs/logs/**/*.log
outputs/logs/**/*.txt
outputs/logs/*
!outputs/logs/.gitkeep

# Saved models and checkpoints
outputs/models/*.pt
outputs/models/*.pth
outputs/models/*.bin
outputs/models/*.h5
outputs/models/*.ckpt
outputs/models/fine_tuned/*
!outputs/models/.gitkeep
!outputs/models/fine_tuned/.gitkeep

# Results
outputs/results/*.json
outputs/results/*.csv
outputs/results/*.xlsx
outputs/results/*
!outputs/results/.gitkeep

# Dashboard cache
outputs/dashboard_cache/*.pkl
outputs/dashboard_cache/*.cache
outputs/dashboard_cache/*.json
outputs/dashboard_cache/visualizations/*
!outputs/dashboard_cache/.gitkeep

# Generated reports
outputs/reports/*.html
outputs/reports/*.pdf
outputs/reports/*.docx
outputs/reports/*
!outputs/reports/.gitkeep

