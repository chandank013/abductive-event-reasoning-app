# ============================================================================
# Keep Important Empty Directories
# ============================================================================
# Use .gitkeep files in empty directories you want to keep
# Example structure (these should NOT be in .gitignore):
# !data/raw/.gitkeep
# !data/processed/train/.gitkeep
# !data/processed/dev/.gitkeep
# !data/processed/test/.gitkeep
# !data/embeddings/.gitkeep
# !outputs/predictions/.gitkeep
# !outputs/logs/.gitkeep
# !outputs/models/.gitkeep
# !outputs/results/.gitkeep
# !outputs/dashboard_cache/.gitkeep
# !outputs/reports/.gitkeep

# ============================================================================
# Optional: Whitelist Specific Files
# ============================================================================
# If you need to force-add certain files that match patterns above:
# !config/model_config.yaml
# !config/training_config.yaml
# !data/sample_data.jsonl